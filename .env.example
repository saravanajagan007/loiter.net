# Database
# Example: mysql://user:password@host:port/database_name
DATABASE_URL="mysql://your_db_user:your_db_password@your_db_host:3306/your_db_name"

# Redis
# Example: redis://127.0.0.1:6379
REDIS_URL="redis://127.0.0.1:6379"

# Auth.js / NextAuth configuration
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET="your_auth_secret_here"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API Key
OPENAI_API_KEY="your_openai_api_key_here"

# Twitter (X) OAuth 2.0 Settings
X_CLIENT_ID="your_x_client_id_here"
X_CLIENT_SECRET="your_x_client_secret_here"
X_CALLBACK_URL="http://localhost:3000/api/social/callback/x"

# Scheduler Settings
CONTENT_FETCH_INTERVAL_MINUTES=60

# Nitter Instance Settings
NITTER_INSTANCE_URL="https://nitter.privacyredirect.com"

# Gemini Configuration
GEMINI_API_KEY="your_gemini_api_key_here"
AI_PROVIDER="gemini"
